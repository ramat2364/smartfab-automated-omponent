# SmartFab Components Backend Local Configuration
# This file is used when running services or tools (like Prisma CLI) locally on the host machine.
# When running in Docker Compose, environment variables defined in docker-compose.yml will override these.

PORT=5001
NODE_ENV=development

# Database Configuration (points to localhost for host development)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smartfactory?schema=public"

# Redis Configuration (points to localhost for host development)
REDIS_URL="redis://localhost:6379"

# JWT Secrets for Auth
JWT_ACCESS_SECRET="super-secret-access-token-key-1234567890"
JWT_REFRESH_SECRET="super-secret-refresh-token-key-0987654321"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Claude AI API (Enter your API Key here to enable real AI generation)
ANTHROPIC_API_KEY=""

# File Storage Config (Simulated locally, points to localhost for host development)
S3_BUCKET_NAME="smartfab-quality-docs"
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_REGION="us-east-1"

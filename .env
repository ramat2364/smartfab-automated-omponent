# SmartFab Components Digital Transformation Platform Config
PORT=5001
NODE_ENV=development

# Database Configuration (Docker Compose refers to the 'postgres' service)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/smartfactory?schema=public

# Redis Configuration (Docker Compose refers to the 'redis' service)
REDIS_URL=redis://redis:6379

# JWT Secrets for Auth
JWT_ACCESS_SECRET=super-secret-access-token-key-1234567890
JWT_REFRESH_SECRET=super-secret-refresh-token-key-0987654321
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Claude AI API (Enter your API Key here to enable real AI generation)
ANTHROPIC_API_KEY=

# File Storage Config (Simulated locally, but ready for S3 configuration)
S3_BUCKET_NAME=smartfab-quality-docs
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
